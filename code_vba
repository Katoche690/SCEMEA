Private Function JsonStr(s As String) As String
    Dim result As String
    result = Replace(s, "\", "\\")
    result = Replace(result, """", "\""")
    result = Replace(result, vbCr, "")
    result = Replace(result, vbLf, "")
    result = Replace(result, vbTab, "\t")
    JsonStr = """" & result & """"
End Function

Private Function ExtractJsonValue(json As String, key As String) As String
    ExtractJsonValue = ""
    Dim searchKey As String
    searchKey = """" & key & """"
    
    Dim pos As Long
    pos = InStr(1, json, searchKey)
    If pos = 0 Then Exit Function
    
    pos = InStr(pos + Len(searchKey), json, ":")
    If pos = 0 Then Exit Function
    pos = pos + 1
    
    Do While Mid(json, pos, 1) = " " Or Mid(json, pos, 1) = vbTab
        pos = pos + 1
    Loop
    
    If Mid(json, pos, 1) = """" Then
        pos = pos + 1
        Dim endPos As Long
        endPos = pos
        Do While endPos <= Len(json)
            If Mid(json, endPos, 1) = """" And Mid(json, endPos - 1, 1) <> "\" Then
                Exit Do
            End If
            endPos = endPos + 1
        Loop
        ExtractJsonValue = Mid(json, pos, endPos - pos)
    Else
        endPos = pos
        Do While endPos <= Len(json) And InStr(",}] " & vbCrLf, Mid(json, endPos, 1)) = 0
            endPos = endPos + 1
        Loop
        ExtractJsonValue = Mid(json, pos, endPos - pos)
    End If
End Function

Private Function SplitJsonDays(json As String) As String()
    Dim result() As String
    Dim trimmed As String
    trimmed = Trim(json)
    
    If Left(trimmed, 1) = "[" Then trimmed = Mid(trimmed, 2)
    If Right(trimmed, 1) = "]" Then trimmed = Left(trimmed, Len(trimmed) - 1)
    
    Dim parts As New Collection
    Dim depth As Long: depth = 0
    Dim start As Long: start = 1
    Dim i As Long
    
    For i = 1 To Len(trimmed)
        Dim ch As String
        ch = Mid(trimmed, i, 1)
        If ch = "{" Or ch = "[" Then depth = depth + 1
        If ch = "}" Or ch = "]" Then depth = depth - 1
        If ch = "," And depth = 0 Then
            parts.Add Trim(Mid(trimmed, start, i - start))
            start = i + 1
        End If
    Next i
    
    If start <= Len(trimmed) Then
        parts.Add Trim(Mid(trimmed, start))
    End If
    
    ReDim result(parts.count - 1)
    For i = 1 To parts.count
        result(i - 1) = parts(i)
    Next i
    
    SplitJsonDays = result
End Function

Private Function EncodeBase64(text As String) As String
    Dim arrBytes() As Byte
    arrBytes = StrConv(text, vbFromUnicode)
    
    Dim objXML As Object
    Dim objNode As Object
    Set objXML = CreateObject("MSXML2.DOMDocument")
    Set objNode = objXML.createElement("b64")
    objNode.DataType = "bin.base64"
    objNode.nodeTypedValue = arrBytes
    EncodeBase64 = Replace(objNode.text, vbLf, "")
End Function

Private Function DecodeBase64(b64 As String) As String
    Dim objXML As Object
    Dim objNode As Object
    Set objXML = CreateObject("MSXML2.DOMDocument")
    Set objNode = objXML.createElement("b64")
    objNode.DataType = "bin.base64"
    objNode.text = b64
    
    Dim arrBytes() As Byte
    arrBytes = objNode.nodeTypedValue
    DecodeBase64 = StrConv(arrBytes, vbUnicode)
End Function

Private Sub SortStringArray(arr() As String)
    Dim i As Long, j As Long, tmp As String
    For i = LBound(arr) To UBound(arr) - 1
        For j = i + 1 To UBound(arr)
            If arr(j) < arr(i) Then
                tmp = arr(i): arr(i) = arr(j): arr(j) = tmp
            End If
        Next j
    Next i
End Sub
