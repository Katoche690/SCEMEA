' ============ LIRE LES CODES OMIS DEPUIS LA FEUILLE CONFIG ============
Private Function GetOmittedCodes() As String()
    Dim result() As String
    Dim ws As Worksheet
    Dim lastRow As Long
    Dim i As Long
    Dim count As Long
    
    On Error Resume Next
    Set ws = ThisWorkbook.Sheets(CONFIG_SHEET)
    On Error GoTo 0
    
    If ws Is Nothing Then
        Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.count))
        ws.Name = CONFIG_SHEET
        ws.Cells(1, 1).Value = "Codes Omis"
        ws.Cells(1, 1).Font.Bold = True
        ws.Cells(1, 1).Interior.Color = RGB(70, 130, 180)
        ws.Cells(1, 1).Font.Color = RGB(255, 255, 255)
        ws.Columns(1).ColumnWidth = 15
        ws.Cells(2, 1).Value = 900
        ws.Cells(3, 1).Value = 213
        ws.Cells(4, 1).Value = 309
        ws.Cells(5, 1).Value = 276
        ws.Cells(6, 1).Value = 3298
        ws.Cells(7, 1).Value = 3273
        MsgBox "La feuille '" & CONFIG_SHEET & "' a ete creee avec des codes par defaut." & vbCrLf & _
               "Modifiez la colonne A pour ajuster les codes a exclure, puis relancez la macro.", _
               vbInformation, "Config creee"
    End If
    
    lastRow = ws.Cells(ws.Rows.count, 1).End(xlUp).Row
    
    If lastRow < 2 Then
        ReDim result(0)
        result(0) = ""
        GetOmittedCodes = result
        Exit Function
    End If
    
    count = 0
    ReDim result(lastRow - 2)
    
    For i = 2 To lastRow
        Dim cellVal As String
        cellVal = Trim(CStr(ws.Cells(i, 1).Value))
        If Len(cellVal) > 0 Then
            result(count) = cellVal
            count = count + 1
        End If
    Next i
    
    If count = 0 Then
        ReDim result(0)
        result(0) = ""
    Else
        ReDim Preserve result(count - 1)
    End If
    
    GetOmittedCodes = result
End Function


' ============ POINT D'ENTREE PRINCIPAL ============
Public Sub UpdateDashboard()

    Dim log As String
    log = ""
    
    On Error GoTo ErrHandler
    
    ' 0. Lire les codes omis depuis la feuille Config
    Dim omittedCodes() As String
    omittedCodes = GetOmittedCodes()
    log = log & "0. Codes omis : " & Join(omittedCodes, ", ") & vbCrLf
    
    ' 1. Chercher TOUS les mails SCEMEA non lus
    log = log & "1. Recherche des mails SCEMEA non lus..." & vbCrLf
    Dim mailPaths As Collection  ' Collection de chemins de fichiers temp
    Dim mailItems As Collection  ' Collection des objets mail Outlook (pour les marquer lus)
    Set mailPaths = New Collection
    Set mailItems = New Collection
    
    FindUnreadAttachments mailPaths, mailItems
    
    If mailPaths.count = 0 Then
        MsgBox "Aucun mail SCEMEA non lu trouve avec piece jointe Excel." & vbCrLf & vbCrLf & _
               "Verifiez que des mails 'SCEMEA #Daily Report-FR' non lus" & vbCrLf & _
               "sont dans votre dossier SCEMEA.", _
               vbExclamation, "SCEMEA Dashboard"
        Exit Sub
    End If
    log = log & "   OK : " & mailPaths.count & " mail(s) non lu(s) trouve(s)" & vbCrLf
    
    ' 2. Lire les donnees de CHAQUE piece jointe et accumuler
    log = log & "2. Lecture des donnees (tous supervisors, " & mailPaths.count & " rapport(s))..." & vbCrLf
    Dim jsonEvents As String
    Dim nbEvents As Long
    Dim supervisorList As String
    jsonEvents = ReadAllMailsData(mailPaths, nbEvents, omittedCodes, supervisorList)
    If jsonEvents = "" Then
        MsgBox "Aucune donnee trouvee dans les rapports.", vbExclamation, "SCEMEA Dashboard"
        ' Nettoyage des fichiers temp meme en cas d'echec
        CleanupTempFiles mailPaths
        Exit Sub
    End If
    log = log & "   OK : " & nbEvents & " evenements extraits" & vbCrLf
    log = log & "   Supervisors : " & supervisorList & vbCrLf
    
    ' 3. Recuperer l'historique GitHub
    log = log & "3. Recuperation historique GitHub..." & vbCrLf
    Dim existingJson As String
    Dim existingSha As String
    GetGithubHistory existingJson, existingSha
    log = log & "   OK : SHA=" & Left(existingSha, 7) & vbCrLf
    
    ' 4. Fusionner
    log = log & "4. Fusion des donnees..." & vbCrLf
    Dim mergedJson As String
    mergedJson = MergeHistory(existingJson, jsonEvents)
    log = log & "   OK" & vbCrLf
    
    ' 5. Pousser vers GitHub
    log = log & "5. Envoi vers GitHub..." & vbCrLf
    Dim success As Boolean
    success = PushToGithub(mergedJson, existingSha)
    
    If success Then
        log = log & "   OK : Pousse avec succes !" & vbCrLf
        
        ' 6. Marquer les mails comme lus
        log = log & "6. Marquage des mails comme lus..." & vbCrLf
        Dim mi As Long
        For mi = 1 To mailItems.count
            mailItems(mi).UnRead = False
        Next mi
        log = log & "   OK : " & mailItems.count & " mail(s) marque(s) lu(s)" & vbCrLf
        
        MsgBox "Mise a jour terminee !" & vbCrLf & vbCrLf & _
               mailPaths.count & " rapport(s) traite(s)" & vbCrLf & _
               nbEvents & " evenements envoyes" & vbCrLf & _
               "Supervisors : " & supervisorList & vbCrLf & vbCrLf & _
               "Les mails ont ete marques comme lus." & vbCrLf & vbCrLf & _
               "Dashboard : https://" & GITHUB_USER & ".github.io/" & GITHUB_REPO & "/", _
               vbInformation, "SCEMEA Dashboard"
    Else
        MsgBox "Donnees extraites mais erreur lors de l'envoi GitHub." & vbCrLf & _
               "Les mails restent non lus." & vbCrLf & _
               "Verifiez votre token et vos permissions.", vbExclamation, "SCEMEA Dashboard"
    End If
    
    ' Nettoyage fichiers temp
    CleanupTempFiles mailPaths
    
    Exit Sub
    
ErrHandler:
    MsgBox "Erreur : " & Err.Description & vbCrLf & vbCrLf & _
           "Les mails restent non lus." & vbCrLf & vbCrLf & _
           "Log :" & vbCrLf & log, vbCritical, "SCEMEA Dashboard - Erreur"
    CleanupTempFiles mailPaths
End Sub


' ============ NETTOYAGE FICHIERS TEMP ============
Private Sub CleanupTempFiles(paths As Collection)
    If paths Is Nothing Then Exit Sub
    Dim i As Long
    On Error Resume Next
    For i = 1 To paths.count
        Kill paths(i)
    Next i
    On Error GoTo 0
End Sub


' ============ 1. CHERCHER TOUS LES MAILS SCEMEA NON LUS ============
Private Sub FindUnreadAttachments(ByRef paths As Collection, ByRef items As Collection)
    
    Dim olApp As Object
    Dim olNs As Object
    
    Set olApp = CreateObject("Outlook.Application")
    Set olNs = olApp.GetNamespace("MAPI")
    
    Dim olInbox As Object
    Dim olFolder As Object
    Set olInbox = olNs.GetDefaultFolder(6)
    
    ' Chercher le dossier SCEMEA
    On Error Resume Next
    Set olFolder = olInbox.Folders("SCEMEA")
    On Error GoTo 0
    
    If olFolder Is Nothing Then
        Dim rootFolder As Object
        Set rootFolder = olInbox.Parent
        On Error Resume Next
        Set olFolder = rootFolder.Folders("SCEMEA")
        On Error GoTo 0
    End If
    
    If olFolder Is Nothing Then
        Dim acct As Object
        For Each acct In olNs.Folders
            On Error Resume Next
            Set olFolder = acct.Folders("SCEMEA")
            On Error GoTo 0
            If Not olFolder Is Nothing Then Exit For
        Next acct
    End If
    
    If olFolder Is Nothing Then
        MsgBox "Dossier 'SCEMEA' introuvable dans Outlook." & vbCrLf & _
               "Verifiez le nom exact du dossier.", vbExclamation, "SCEMEA Dashboard"
        Exit Sub
    End If
    
    ' Trier par date croissante (plus ancien d'abord ГўвЂ вЂ™ traitement chronologique)
    Dim olItems As Object
    Set olItems = olFolder.items
    olItems.Sort "[ReceivedTime]", False
    
    ' Parcourir tous les mails non lus
    Dim item As Object
    Dim mailCount As Long: mailCount = 0
    
    For Each item In olItems
        ' Verifier : mail (Class=43), non lu, bon sujet, bon expediteur
        If item.Class = 43 Then
            If item.UnRead Then
                If InStr(1, item.Subject, MAIL_SUBJECT, vbTextCompare) > 0 Then
                    If InStr(1, item.SenderEmailAddress, MAIL_SENDER, vbTextCompare) > 0 Or _
                       InStr(1, item.SenderName, "SCEMEA", vbTextCompare) > 0 Then
                        
                        ' Chercher la piece jointe Excel
                        Dim att As Object
                        For Each att In item.Attachments
                            If LCase(Right(att.FileName, 5)) = ".xlsx" Or _
                               LCase(Right(att.FileName, 4)) = ".xls" Then
                                
                                mailCount = mailCount + 1
                                Dim tempPath As String
                                tempPath = Environ("TEMP") & "\SCEMEA_" & Format(Now, "yyyyMMdd_HHmmss") & "_" & mailCount & ".xlsx"
                                att.SaveAsFile tempPath
                                paths.Add tempPath
                                items.Add item
                                Exit For ' Un seul fichier Excel par mail
                            End If
                        Next att
                    End If
                End If
            End If
        End If
    Next item
End Sub


' ============ 2. LIRE LES DONNEES DE TOUS LES MAILS ============
Private Function ReadAllMailsData(mailPaths As Collection, ByRef nbEvents As Long, omitArr() As String, ByRef supervisorList As String) As String
    ReadAllMailsData = ""
    nbEvents = 0
    supervisorList = ""
    
    ' Dictionnaire global qui accumule tous les evenements de tous les mails
    Dim dict As Object
    Set dict = CreateObject("Scripting.Dictionary")
    
    ' Tracker les supervisors trouves
    Dim supDict As Object
    Set supDict = CreateObject("Scripting.Dictionary")
    
    ' Traiter chaque fichier Excel
    Dim fi As Long
    For fi = 1 To mailPaths.count
        ReadOneFile mailPaths(fi), dict, supDict, omitArr
    Next fi
    
    If dict.count = 0 Then Exit Function
    
    ' Construire la liste des supervisors
    Dim supKey As Variant
    Dim supList As String: supList = ""
    For Each supKey In supDict.Keys
        If Len(supList) > 0 Then supList = supList & ", "
        supList = supList & CStr(supKey)
    Next supKey
    supervisorList = supList
    
    ' Construire le JSON par jour
    Dim dateDict As Object
    Set dateDict = CreateObject("Scripting.Dictionary")
    
    Dim k As Variant
    Dim arr As Variant
    For Each k In dict.Keys
        arr = dict(k)
        Dim dt As String
        dt = arr(0) ' date
        
        Dim evJson As String
        evJson = "{" & _
            """supervisor"":" & JsonStr(CStr(arr(1))) & "," & _
            """code"":" & JsonStr(CStr(arr(2))) & "," & _
            """event"":" & JsonStr(CStr(arr(3))) & "," & _
            """severity"":" & JsonStr(CStr(arr(4))) & "," & _
            """park"":" & JsonStr(CStr(arr(5))) & "," & _
            """count"":" & arr(6) & "," & _
            """lastSeen"":" & JsonStr(CStr(arr(7))) & "," & _
            """turbines"":" & JsonStr(CStr(arr(8))) & _
            "}"
        
        nbEvents = nbEvents + CLng(arr(6))
        
        If dateDict.Exists(dt) Then
            dateDict(dt) = dateDict(dt) & "," & evJson
        Else
            dateDict.Add dt, evJson
        End If
    Next k
    
    ' Construire le JSON final trie par date
    Dim dayJsonParts() As String
    ReDim dayJsonParts(dateDict.count - 1)
    Dim idx As Long: idx = 0
    
    Dim dateKeys() As String
    ReDim dateKeys(dateDict.count - 1)
    Dim di As Long: di = 0
    For Each k In dateDict.Keys
        dateKeys(di) = CStr(k)
        di = di + 1
    Next k
    SortStringArray dateKeys
    
    For di = LBound(dateKeys) To UBound(dateKeys)
        dayJsonParts(idx) = "{""date"":" & JsonStr(dateKeys(di)) & ",""events"":[" & dateDict(dateKeys(di)) & "]}"
        idx = idx + 1
    Next di
    
    ReadAllMailsData = Join(dayJsonParts, ",")
End Function


' ============ LIRE UN FICHIER EXCEL ET ACCUMULER DANS LE DICTIONNAIRE ============
Private Sub ReadOneFile(excelPath As String, ByRef dict As Object, ByRef supDict As Object, omitArr() As String)
    
    Dim wbSource As Workbook
    Dim wsSource As Worksheet
    Dim lastRow As Long, lastCol As Long
    
    Application.ScreenUpdating = False
    Set wbSource = Workbooks.Open(excelPath, ReadOnly:=True, UpdateLinks:=False)
    Set wsSource = wbSource.Sheets(1)
    
    lastRow = wsSource.UsedRange.Rows.count
    lastCol = wsSource.UsedRange.Columns.count
    
    ' Trouver les colonnes par en-tete
    Dim colSup As Long, colPark As Long, colTurbine As Long
    Dim colTime As Long, colCode As Long, colText As Long, colSev As Long
    Dim c As Long
    
    For c = 1 To lastCol
        Dim hdr As String
        hdr = LCase(Trim(CStr(wsSource.Cells(1, c).Value)))
        If InStr(hdr, "site") > 0 And InStr(hdr, "supervisor") > 0 Then colSup = c
        If InStr(hdr, "park") > 0 And InStr(hdr, "name") > 0 Then colPark = c
        If InStr(hdr, "turbine") > 0 And InStr(hdr, "name") > 0 Then colTurbine = c
        If InStr(hdr, "event") > 0 And InStr(hdr, "time") > 0 Then colTime = c
        If InStr(hdr, "event") > 0 And InStr(hdr, "code") > 0 Then colCode = c
        If InStr(hdr, "event") > 0 And InStr(hdr, "text") > 0 Then colText = c
        If hdr = "severity" Then colSev = c
    Next c
    
    If colSup = 0 Or colCode = 0 Then
        wbSource.Close False
        Application.ScreenUpdating = True
        Exit Sub
    End If
    
    Dim r As Long
    For r = 2 To lastRow
        Dim sup As String
        sup = Trim(CStr(wsSource.Cells(r, colSup).Value))
        
        If Len(sup) = 0 Then GoTo NextRow
        
        If Not supDict.Exists(sup) Then supDict.Add sup, True
        
        Dim evCode As String
        evCode = Trim(CStr(wsSource.Cells(r, colCode).Value))
        
        ' Verifier si code omis
        Dim isOmitted As Boolean
        isOmitted = False
        Dim oi As Long
        For oi = LBound(omitArr) To UBound(omitArr)
            If Trim(omitArr(oi)) = evCode Then isOmitted = True: Exit For
        Next oi
        If isOmitted Then GoTo NextRow
        
        Dim evText As String, evSev As String, evPark As String, evTurb As String
        evText = Trim(CStr(wsSource.Cells(r, colText).Value))
        evSev = Trim(CStr(wsSource.Cells(r, colSev).Value))
        evPark = Trim(CStr(wsSource.Cells(r, colPark).Value))
        If colTurbine > 0 Then evTurb = Trim(CStr(wsSource.Cells(r, colTurbine).Value)) Else evTurb = ""
        
        ' Date
        Dim evDate As String, evTime As String
        Dim rawTime As Variant
        rawTime = wsSource.Cells(r, colTime).Value
        If IsDate(rawTime) Then
            evDate = Format(CDate(rawTime), "yyyy-mm-dd")
            evTime = Format(CDate(rawTime), "dd/mm hh:nn")
        Else
            evDate = Format(Now, "yyyy-mm-dd")
            evTime = CStr(rawTime)
        End If
        
        ' Cle de regroupement : inclut le supervisor
        Dim key As String
        key = evDate & "|" & sup & "|" & evCode & "|" & evText & "|" & evSev & "|" & evPark
        
        If dict.Exists(key) Then
            Dim arr As Variant
            arr = dict(key)
            arr(6) = arr(6) + 1 ' count
            If Len(evTurb) > 0 And InStr(arr(8), evTurb) = 0 Then
                If Len(arr(8)) > 0 Then arr(8) = arr(8) & ", " & evTurb Else arr(8) = evTurb
            End If
            If evTime > arr(7) Then arr(7) = evTime ' lastSeen
            dict(key) = arr
        Else
            ' Array(date, supervisor, code, event, severity, park, count, lastSeen, turbines)
            dict.Add key, Array(evDate, sup, evCode, evText, evSev, evPark, 1, evTime, evTurb)
        End If
NextRow:
    Next r
    
    wbSource.Close False
    Application.ScreenUpdating = True
End Sub


' ============ 3. RECUPERER HISTORIQUE GITHUB ============
Private Sub GetGithubHistory(ByRef existingJson As String, ByRef existingSha As String)
    existingJson = ""
    existingSha = ""
    
    Dim url As String
    url = "https://api.github.com/repos/" & GITHUB_USER & "/" & GITHUB_REPO & "/contents/" & HISTORY_FILE & "?ref=" & GITHUB_BRANCH
    
    Dim http As Object
    Set http = CreateObject("MSXML2.XMLHTTP.6.0")
    http.Open "GET", url, False
    http.setRequestHeader "Authorization", "Bearer " & GITHUB_TOKEN
    http.setRequestHeader "Accept", "application/vnd.github+json"
    http.setRequestHeader "User-Agent", "SCEMEA-VBA-Updater"
    http.Send
    
    If http.Status = 200 Then
        Dim respText As String
        respText = http.responseText
        
        existingSha = ExtractJsonValue(respText, "sha")
        
        Dim b64Content As String
        b64Content = ExtractJsonValue(respText, "content")
        b64Content = Replace(b64Content, "\n", "")
        b64Content = Replace(b64Content, vbLf, "")
        b64Content = Replace(b64Content, vbCr, "")
        
        existingJson = DecodeBase64(b64Content)
        
        existingJson = Trim(existingJson)
        If Len(existingJson) > 0 And AscW(Left(existingJson, 1)) = 65279 Then
            existingJson = Mid(existingJson, 2)
        End If
        If Left(existingJson, 1) <> "[" Then existingJson = ""
        If Len(existingJson) > 0 And Right(existingJson, 1) <> "]" Then existingJson = ""
        
    ElseIf http.Status = 404 Then
        existingJson = ""
        existingSha = ""
    Else
        Err.Raise vbObjectError + 1, , "Erreur API GitHub GET: " & http.Status & " - " & http.responseText
    End If
End Sub


' ============ 4. FUSIONNER HISTORIQUE ============
Private Function MergeHistory(existingJson As String, newDaysJson As String) As String
    If existingJson = "" Or existingJson = "[]" Then
        MergeHistory = "[" & newDaysJson & "]"
        Exit Function
    End If
    
    Dim dateDict As Object
    Set dateDict = CreateObject("Scripting.Dictionary")
    
    Dim existingDays() As String
    existingDays = SplitJsonDays(existingJson)
    
    Dim i As Long
    For i = LBound(existingDays) To UBound(existingDays)
        If Len(Trim(existingDays(i))) > 0 Then
            Dim existDate As String
            existDate = ExtractJsonValue(existingDays(i), "date")
            If Len(existDate) > 0 Then
                dateDict(existDate) = existingDays(i)
            End If
        End If
    Next i
    
    Dim newDays() As String
    newDays = SplitJsonDays("[" & newDaysJson & "]")
    
    For i = LBound(newDays) To UBound(newDays)
        If Len(Trim(newDays(i))) > 0 Then
            Dim newDate As String
            newDate = ExtractJsonValue(newDays(i), "date")
            If Len(newDate) > 0 Then
                dateDict(newDate) = newDays(i)
            End If
        End If
    Next i
    
    Dim allDates() As String
    ReDim allDates(dateDict.count - 1)
    Dim di As Long: di = 0
    Dim k As Variant
    For Each k In dateDict.Keys
        allDates(di) = CStr(k)
        di = di + 1
    Next k
    SortStringArray allDates
    
    Dim parts() As String
    ReDim parts(UBound(allDates))
    For i = LBound(allDates) To UBound(allDates)
        parts(i) = dateDict(allDates(i))
    Next i
    
    MergeHistory = "[" & Join(parts, ",") & "]"
End Function


' ============ 5. POUSSER VERS GITHUB ============
Private Function PushToGithub(jsonContent As String, sha As String) As Boolean
    PushToGithub = False
    
    Dim url As String
    url = "https://api.github.com/repos/" & GITHUB_USER & "/" & GITHUB_REPO & "/contents/" & HISTORY_FILE
    
    Dim b64Content As String
    b64Content = EncodeBase64(jsonContent)
    
    Dim today As String
    today = Format(Now, "yyyy-mm-dd hh:nn")
    
    Dim body As String
    body = "{" & _
        """message"":" & JsonStr("data: update " & today) & "," & _
        """content"":" & JsonStr(b64Content) & "," & _
        """branch"":" & JsonStr(GITHUB_BRANCH)
    
    If Len(sha) > 0 Then
        body = body & ",""sha"":" & JsonStr(sha)
    End If
    body = body & "}"
    
    Dim http As Object
    Set http = CreateObject("MSXML2.XMLHTTP.6.0")
    http.Open "PUT", url, False
    http.setRequestHeader "Authorization", "Bearer " & GITHUB_TOKEN
    http.setRequestHeader "Accept", "application/vnd.github+json"
    http.setRequestHeader "Content-Type", "application/json"
    http.setRequestHeader "User-Agent", "SCEMEA-VBA-Updater"
    http.Send body
    
    If http.Status = 200 Or http.Status = 201 Then
        PushToGithub = True
    Else
        Debug.Print "GitHub PUT error: " & http.Status & " - " & http.responseText
    End If
End Function


